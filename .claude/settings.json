{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/guard-irreversible.py\"",
            "timeout": 10,
            "statusMessage": "비가역 가드 (push·배포 → 승인 / rm 파국 차단)"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/brain-freshness.py\"",
            "timeout": 10,
            "statusMessage": "federation 신선도 (.brain vs HEAD)"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/validate-stop.sh\"",
            "timeout": 30,
            "statusMessage": "advisory scan (secret + 산출물 누출)"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/brain-freshness.py\"",
            "timeout": 10,
            "statusMessage": "federation 신선도 (.brain vs HEAD)"
          }
        ]
      }
    ]
  }
}
